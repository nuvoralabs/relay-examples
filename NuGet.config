<?xml version="1.0" encoding="utf-8"?>
<!-- Generated by the examples-repo sync in nuvora-nexus-net. Do not edit. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="nuvoralabs" value="https://nuget.pkg.github.com/nuvoralabs/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="nuvoralabs">
      <package pattern="Nuvora.Nexus.Relay*" />
    </packageSource>
  </packageSourceMapping>
  <!-- GitHub Packages requires authentication even for public feeds. Export
       GITHUB_ACTOR (your username) and GITHUB_TOKEN (a PAT with read:packages)
       before restoring; see the README. -->
  <packageSourceCredentials>
    <nuvoralabs>
      <add key="Username" value="%GITHUB_ACTOR%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </nuvoralabs>
  </packageSourceCredentials>
</configuration>
