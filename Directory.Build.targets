<Project>

  <!--
    Package-mode reference switch (see Directory.Build.props). When the framework source is
    not present ($(RelayUseSource) != true — i.e. building the public examples mirror), every
    ProjectReference to a framework project (all named Nuvora.Nexus.Relay*) is replaced by a
    PackageReference to the identically-named NuGet package at $(RelayVersion). Sample-to-sample
    ProjectReferences are untouched. Inside the monorepo this file is a no-op.
  -->
  <ItemGroup Condition="'$(RelayUseSource)' != 'true'">
    <_RelayFrameworkReference Include="@(ProjectReference)"
                              Condition="$([System.String]::Copy('%(Filename)').StartsWith('Nuvora.Nexus.Relay'))" />
    <ProjectReference Remove="@(_RelayFrameworkReference)" />
    <PackageReference Include="@(_RelayFrameworkReference->'%(Filename)')" Version="$(RelayVersion)" />
  </ItemGroup>

  <Target Name="_RelayVersionSanityCheck" BeforeTargets="CollectPackageReferences;ResolveAssemblyReferences"
          Condition="'$(RelayUseSource)' != 'true' and '$(RelayVersion)' == '' and '@(_RelayFrameworkReference)' != ''">
    <Error Text="RelayVersion is not set. Building the samples outside the monorepo requires relay-version.props (generated by the examples-repo sync) or -p:RelayVersion=&lt;version&gt;." />
  </Target>

</Project>
